# Database connection (get a free PostgreSQL at https://neon.tech)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# OpenAI API Key (for AI debate features)
GEMINI_API_KEY=sk-...

# Session secret (generate a random string for production)
SESSION_SECRET=your-random-secret-here

# Stripe (use test keys for development; get webhook secret from Stripe Dashboard or `stripe listen`)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
