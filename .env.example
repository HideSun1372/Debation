# Database connection (get a free PostgreSQL at https://neon.tech)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Client API/WebSocket base URL (optional - for dev or custom deploy)
# Examples: http://localhost:5000, http://127.0.0.1:5000, http://10.0.0.236:5000,
#           https://hidesun1372.instatunnel.my, https://hidesun1372.onrender.com, https://hidesun1372.vercel.app
# WebSocket URL is derived automatically (http->ws, https->wss). Override with VITE_WS_BASE_URL if needed.
VITE_API_BASE_URL=

# OpenAI API Key (for AI debate features)
GEMINI_API_KEY=sk-...

# Session secret (generate a random string for production)
SESSION_SECRET=your-random-secret-here

# Stripe (use test keys for development; get webhook secret from Stripe Dashboard or `stripe listen`)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
